{
  "id": "trumpet-synth",
  "name": "Trumpet Synth",
  "abbrev": "TrSyn",
  "version": "0.4.0",
  "description": "Pitch-tracking synthesizer. Audio in → autocorrelation pitch detection → oscillator → output.",
  "author": "andrewcolman",
  "dsp": "trumpet-synth.so",
  "ui": "ui.js",
  "ui_chain": "ui_chain.js",
  "api_version": 2,
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "modes": null,
      "levels": {
        "root": {
          "name": "Trumpet Synth",
          "knobs": [
            "gate_threshold",
            "filter_cutoff",
            "filter_resonance",
            "volume"
          ],
          "params": [
            { "level": "Input",      "label": "Input"      },
            { "level": "Oscillator", "label": "Oscillator" },
            { "level": "Filter",     "label": "Filter"     }
          ]
        },
        "Input": {
          "label": "Input",
          "knobs": [
            "gate_threshold",
            "pitch_smooth",
            "input_gain",
            "pitch_confidence"
          ],
          "params": [
            { "key": "input_gain",       "label": "Input Gain",  "type": "float", "min": 0.0, "max": 4.0,  "default": 1.0,   "step": 0.01 },
            { "key": "gate_threshold",   "label": "Gate",        "type": "float", "min": 0.0, "max": 0.1,  "default": 0.015, "step": 0.001 },
            { "key": "pitch_confidence", "label": "Confidence",  "type": "float", "min": 0.0, "max": 1.0,  "default": 0.0,   "step": 0.01 },
            { "key": "pitch_smooth",     "label": "Pitch Smooth","type": "float", "min": 0.0, "max": 1.0,  "default": 0.005, "step": 0.005 },
            { "key": "vol_tracking",     "label": "Vol Track",   "type": "float", "min": 0.0, "max": 1.0,  "default": 0.8,   "step": 0.01 }
          ]
        },
        "Oscillator": {
          "label": "Oscillator",
          "knobs": [
            "osc_wave",
            "osc_detune",
            "osc_level",
            "volume"
          ],
          "params": [
            { "key": "osc_wave",   "label": "Waveform", "type": "enum",  "options": ["sine", "triangle", "saw", "square"], "default": 2 },
            { "key": "osc_detune", "label": "Detune",   "type": "float", "min": -100.0, "max": 100.0, "default": 0.0, "step": 1.0, "unit": "ct" },
            { "key": "osc_level",  "label": "Level",    "type": "float", "min": 0.0,    "max": 1.0,   "default": 0.8, "step": 0.01 },
            { "key": "volume",     "label": "Volume",   "type": "float", "min": 0.0,    "max": 1.0,   "default": 0.8, "step": 0.01 }
          ]
        },
        "Filter": {
          "label": "Filter",
          "knobs": [
            "filter_cutoff",
            "filter_resonance"
          ],
          "params": [
            { "key": "filter_cutoff",    "label": "Cutoff",    "type": "float", "min": 20.0, "max": 20000.0, "default": 20000.0, "step": 10.0, "unit": "Hz" },
            { "key": "filter_resonance", "label": "Resonance", "type": "float", "min": 0.0,  "max": 1.0,     "default": 0.3,    "step": 0.01 }
          ]
        }
      }
    }
  }
}
